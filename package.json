{
  "name": "businessdna",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:business-library": "tsx business-library/validate.ts",
    "validate:business-library-packages": "tsx business-library/validate-packages.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:business-engine": "tsx prisma/seed-business-engine.ts",
    "db:studio": "prisma studio",
    "matching-engine:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/matching-engine-integration-check.ts",
    "results-pipeline:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/results-pipeline-integration-check.ts",
    "answer-persistence:check": "tsx scripts/answer-persistence-check.ts",
    "budget-weight:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/budget-weight-before-after-check.ts",
    "adopt-business-match:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/adopt-business-match-check.ts",
    "section-trigger:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/section-generation-trigger-check.ts",
    "section-generation:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/section-generation-real-check.ts",
    "section-locale-fix:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/section-locale-fix-check.ts",
    "roadmap-seed:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/roadmap-seed-check.ts",
    "my-businesses-listing:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/my-businesses-listing-check.ts",
    "roadmap-enrichment:check": "NODE_OPTIONS=--conditions=react-server tsx scripts/roadmap-ai-enrichment-check.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.9.13",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@vercel/functions": "^3.7.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next": "^14.2.21",
    "next-intl": "^3.26.3",
    "next-themes": "^0.4.4",
    "openai": "^4.76.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.0",
    "stripe": "^17.4.0",
    "svix": "^1.42.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
